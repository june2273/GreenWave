<?xml version="1.0" encoding="UTF-8"?>
<!--
  3x2 base sumocfg
  Topology: 2 cols x 3 rows (세로 긴 형태), 모든 edge 2-lane
-->
<configuration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/sumoConfiguration.xsd">
  <input>
    <net-file value="3x2.net.xml"/>
    <route-files value="routes_3x2.rou.xml"/>
  </input>
  <time>
    <begin value="0"/>
    <end value="3600"/>
  </time>
</configuration>
