<?xml version="1.0" encoding="UTF-8"?>
<!--
  3x2 BRT sumocfg
  Topology: 2 cols x 3 rows, 좌측 vertical (col 1) = BRT corridor (3-lane)
-->
<configuration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/sumoConfiguration.xsd">
  <input>
    <net-file value="3x2_brt.net.xml"/>
    <route-files value="routes_3x2_brt.rou.xml"/>
  </input>
  <time>
    <begin value="0"/>
    <end value="3600"/>
  </time>
</configuration>
